OPENAI_API_KEY=sk-...
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Demo video (private Supabase Storage — signed URL generated at runtime)
# DEMO_VIDEO_BUCKET=demo-assets
# DEMO_VIDEO_PATH=qaweaver-demo.mp4
# DEMO_VIDEO_SIGNED_URL_TTL=86400

# Optional overrides
OPENAI_CHAT_MODEL=gpt-5.4-mini
# Set this to a stronger model than OPENAI_CHAT_MODEL if you want better testcase writing quality.
# Example: OPENAI_GENERATION_MODEL=gpt-5.4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Where to show the OpenAI key warning banner: sidebar | main | both
OPENAI_KEY_BANNER=sidebar
# Cache validated key status for N seconds (0 = probe on every check)
# OPENAI_KEY_PROBE_TTL_SECONDS=300

# Generation pipeline
# Optional: set to 1 to auto-fill coverage gaps once during the first Generate run
# (incomplete requirements can also be filled via the Generate page button).
MAX_COVERAGE_REVIEW_ROUNDS=0
GEN_RULE_BATCH_SIZE=8
GEN_PARALLEL_WORKERS=3
RAG_LINK_MIN_SIMILARITY=0.55
ANALYST_MAX_RULES=20
# OPENAI_ANALYST_MODEL=gpt-4o-mini

# RAG retrieval (Import bugs/TCs first for history-aware generation)
RETRIEVAL_TOP_K=12
RETRIEVAL_TOP_K_PER_RULE=4
RETRIEVAL_MATCH_THRESHOLD=0.15
# Relevance guard (5.2d): drop history below this similarity or with foreign-domain tokens
RAG_RELEVANCE_MIN_SIMILARITY=0.28
RAG_MAX_FOREIGN_TOKEN_RATIO=0.45
DEDUP_SIMILARITY_THRESHOLD=0.88
BATCH_DEDUP_SIMILARITY_THRESHOLD=0.90

# TestCase Library search settings
LIBRARY_SEARCH_THRESHOLD=0.25
LIBRARY_SEARCH_MATCH_COUNT=25

# Oracle validation (profile-driven heuristics; optional LLM pass)
# ORACLE_USE_LLM=true
# Create a project at https://smith.langchain.com and paste your API key below.
# LANGCHAIN_* and LANGSMITH_* prefixes are both accepted by the SDK.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_API_KEY=lsv2_pt_...
# LANGCHAIN_PROJECT=TestGeneration-AI
