OPENAI_API_KEY=sk-...
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional overrides
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Generation pipeline
MAX_COVERAGE_REVIEW_ROUNDS=0
GEN_RULE_BATCH_SIZE=8
GEN_PARALLEL_WORKERS=3
RAG_LINK_MIN_SIMILARITY=0.55
ANALYST_MAX_RULES=20
# OPENAI_ANALYST_MODEL=gpt-4o-mini

# RAG retrieval (Import bugs/TCs first for history-aware generation)
RETRIEVAL_TOP_K=12
RETRIEVAL_TOP_K_PER_RULE=4
RETRIEVAL_MATCH_THRESHOLD=0.15
DEDUP_SIMILARITY_THRESHOLD=0.88
